        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\n\nactor \&quot;Voluntario\&quot; as Vol\nactor \&quot;Coordinador\&quot; as Coord\n\n&#39; El Coordinador hereda todo lo que puede hacer el Voluntario\nCoord -up-|&gt; Vol\n\npackage \&quot;Gestión de Usuarios\&quot; {\n  usecase \&quot;Registrarse como Voluntario\&quot; as UC_RegVol\n  usecase \&quot;Registrar nuevo Coordinador\&quot; as UC_RegCoord\n  usecase \&quot;Listar Usuarios\&quot; as UC_ListUsers\n}\n\npackage \&quot;Gestión de Tareas\&quot; {\n  usecase \&quot;Listar/Consultar Tareas\&quot; as UC_ListTasks\n  usecase \&quot;Crear/Editar Tarea\&quot; as UC_CreateTask\n  usecase \&quot;Eliminar Tarea\&quot; as UC_DelTask\n}\n\npackage \&quot;Gestión de Animales\&quot; {\n  usecase \&quot;Listar/Consultar Animales\&quot; as UC_ListAnim\n  usecase \&quot;Registrar/Actualizar Animal\&quot; as UC_CreateAnim\n  usecase \&quot;Eliminar Animal\&quot; as UC_DelAnim\n}\n\n&#39; Relaciones específicas\nVol --&gt; UC_ListTasks\nVol --&gt; UC_RegVol\n\nCoord --&gt; UC_RegCoord\nCoord --&gt; UC_ListUsers\nCoord --&gt; UC_CreateTask\nCoord --&gt; UC_DelTask\nCoord --&gt; UC_ListAnim\nCoord --&gt; UC_CreateAnim\nCoord --&gt; UC_DelAnim\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Ii21epzXJ63294IlQwMD-21">
